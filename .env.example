# Optional custom user agent for Reddit public JSON endpoints.
REDDIT_USER_AGENT=mistral-weekly-sentiment/0.1 by your-reddit-username

# LLM provider configuration
LLM_PROVIDER=mistral
LLM_MODEL=

# Mistral AI configuration (default provider)
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-medium-2508

# Claude configuration (optional alternative provider)
ANTHROPIC_API_KEY=

# Google Sheets export (optional)
# GOOGLE_SHEETS_WRITE=true
GOOGLE_SHEETS_SPREADSHEET_ID=1WmjMDPnTO4ZyOLR0lfDQ8CB-yaRZEWj_Uv2Y58jQj8g
GOOGLE_SHEETS_SUMMARY_WORKSHEET=sentiment_summary
GOOGLE_SHEETS_KEYWORDS_WORKSHEET=keyword_mentions
# GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={...}

# Optional runtime tuning
# REDDIT_POST_LIMIT=300
# REDDIT_COMMENT_LIMIT=1000
# LLM_MAX_ITEMS=250
# LLM_MAX_CHARS_PER_ITEM=1200
# CLAUDE_MODEL=claude-sonnet-4-6
